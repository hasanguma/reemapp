# ==============================================
# ملف متغيرات البيئة - مشروع "ريم" (Reem Assistant)
# ==============================================
# قم بنسخ هذا الملف باسم .env وضع مفتاحك الحقيقي بداخله
# احصل على مفتاح Gemini API مجاناً من:
# https://aistudio.google.com/app/apikey

GEMINI_API_KEY=AQ.Ab8RN6IxpvKCDZqD9uN5iiIHuZ21mLSdx5_LfacPlhmR8d7Ubg


# منفذ تشغيل السيرفر (اختياري - القيمة الافتراضية 3000)
PORT=3000

# المنطقة الزمنية المستخدمة لمعرفة "ريم" بالوقت والتاريخ الحاليين (اختياري)
# القيمة الافتراضية: Asia/Riyadh — يمكن تغييرها لأي منطقة زمنية بصيغة IANA
# مثال: Africa/Cairo أو Asia/Dubai أو Europe/Istanbul
TIMEZONE=Asia/Riyadh
